{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["node"],
    "paths": {
      "@earendil-works/pi-coding-agent": ["./node_modules/@earendil-works/pi-coding-agent"],
      "@earendil-works/pi-ai": ["./node_modules/@earendil-works/pi-ai"],
      "@earendil-works/pi-tui": ["./node_modules/@earendil-works/pi-tui"],
      "typebox": ["./node_modules/typebox"]
    }
  },
  "include": ["extensions/**/*.ts"],
  "exclude": ["node_modules"]
}
